generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── СПРАВОЧНИКИ ─────────────────────────────────────────────

model Grade {
  id       Int    @id @default(autoincrement())
  number   Int    @unique
  slug     String @unique
  label_az String
  label_ru String

  subjects GradeSubject[]

  @@map("grades")
}

model Subject {
  id       Int     @id @default(autoincrement())
  slug     String  @unique
  label_az String
  label_ru String
  icon     String?

  grades GradeSubject[]

  @@map("subjects")
}

model GradeSubject {
  grade_id   Int
  subject_id Int
  grade      Grade   @relation(fields: [grade_id], references: [id])
  subject    Subject @relation(fields: [subject_id], references: [id])

  curriculum_items CurriculumItem[]

  @@id([grade_id, subject_id])
  @@index([grade_id, subject_id])
  @@map("grade_subjects")
}

// ─── УЧЕБНЫЙ ПЛАН ─────────────────────────────────────────────

model CurriculumItem {
  id          Int    @id @default(autoincrement())
  grade_id    Int
  subject_id  Int
  slug        String
  title_az    String
  title_ru    String
  order_index Int    @default(0)
  parent_id   Int?

  grade_subject GradeSubject     @relation(fields: [grade_id, subject_id], references: [grade_id, subject_id])
  parent        CurriculumItem?  @relation("SubTopics", fields: [parent_id], references: [id])
  children      CurriculumItem[] @relation("SubTopics")
  resources     Resource[]
  assignments   Assignment[]

  @@unique([grade_id, subject_id, slug])
  @@index([grade_id, subject_id, order_index])
  @@index([parent_id])
  @@map("curriculum_items")
}

// ─── РЕСУРСЫ ──────────────────────────────────────────────────

enum ResourceType {
  LESSON
  TEST
  TAIM_TEST
  BSQ
  KSQ
  WORKBOOK
  VIDEO
}

model Resource {
  id            Int          @id @default(autoincrement())
  curriculum_id Int
  type          ResourceType
  slug          String
  title_az      String
  title_ru      String
  content_url   String?
  metadata      Json?
  is_published  Boolean      @default(false)
  created_at    DateTime     @default(now())

  curriculum_item CurriculumItem @relation(fields: [curriculum_id], references: [id])

  @@unique([curriculum_id, slug])
  @@index([curriculum_id, type])
  @@index([type, is_published])
  @@map("resources")
}

// ─── NƏTICƏLƏR (Supabase vasitəsilə idarə olunur) ─────────────

model Result {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_name  String
  student_class String    @default("")
  platform      String
  lesson_id     String    @default("")
  lesson_title  String    @default("")
  score         Int
  total         Int
  percent       Int
  answers       Json      @default("{}")
  started_at    DateTime?
  finished_at   DateTime?
  created_at    DateTime  @default(now())

  @@map("results")
}

// ─── ŞAGIRDLƏR ────────────────────────────────────────────────

model Student {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  class_name String
  group_name String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  assignments Assignment[]

  @@map("students")
}

model Assignment {
  id         Int       @id @default(autoincrement())
  class_name String?
  group_name String?
  student_id String?
  item_id    Int
  due_date   DateTime?
  note       String?
  status     String    @default("OPEN")
  created_at DateTime  @default(now())

  item    CurriculumItem @relation(fields: [item_id], references: [id], onDelete: Cascade)
  student Student?       @relation(fields: [student_id], references: [id], onDelete: SetNull)

  // Partial unique indexes must be created via raw SQL migration:
  //   CREATE UNIQUE INDEX uq_assignment_class_item
  //     ON assignments (class_name, item_id)
  //     WHERE group_name IS NULL AND student_id IS NULL;
  //   CREATE UNIQUE INDEX uq_assignment_group_item
  //     ON assignments (class_name, group_name, item_id)
  //     WHERE student_id IS NULL;
  //   CREATE UNIQUE INDEX uq_assignment_student_item
  //     ON assignments (student_id, item_id)
  //     WHERE class_name IS NULL;
  // Until that migration runs, duplicate-prevention is handled by skipDuplicates in activate route.
  @@index([class_name, item_id])
  @@index([student_id, item_id])
  @@map("assignments")
}
